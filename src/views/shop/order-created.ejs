<%- include('../includes/head') %>
<%- include('../includes/navigation') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow-sm border-0 text-center">
        <div class="card-body p-5">
          <div class="mb-4">
            <i class="bi bi-envelope-check fs-1 text-primary"></i>
          </div>
          <h1 class="h3 mb-3">Porudžbina je kreirana!</h1>
          <p class="text-muted mb-4">
            Poslali smo vam verifikacioni link na adresu
            <strong><%= data.email %></strong>.
            Kliknite na link u email-u da biste potvrdili porudžbinu.
          </p>
          <div class="alert alert-info">
            <i class="bi bi-clock-history me-2"></i>
            Link važi do: <strong><%= data.tokenExpiration %></strong>
          </div>
          <hr class="my-4">
          <p class="small text-muted">
            Niste dobili email? Proverite spam folder ili
            <a href="/prodavnica/checkout">pokušajte ponovo</a>.
          </p>
          <a href="/" class="btn btn-primary mt-3">
            <i class="bi bi-house-door me-2"></i>Nazad na početnu
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../includes/footer') %>