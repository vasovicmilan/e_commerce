<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container py-4">
  <!-- 🔥 DEFINISANJE MRVICA -->
  <%
    let breadcrumbs = [
      { label: 'Početna', url: '/' },
      { label: 'Prodavnica', url: '/prodavnica' }
    ];
    if (data.category && data.category.slug) {
      breadcrumbs.push({ label: data.category.name, url: null });
    } else if (data.tag && data.tag.name) {
      breadcrumbs.push({ label: data.tag.name, url: null });
    } else if (data.title) {
      breadcrumbs.push({ label: data.title, url: null });
    } else {
      breadcrumbs.push({ label: 'Prodavnica', url: null });
    }
  %>
  <%- include("../includes/breadcrumbs", { breadcrumbs: breadcrumbs }) %>
  <%- include("../includes/flash-messages") %>
  
  <div class="row">
    <!-- Proizvodi (LEVO) -->
    <div class="col-lg-9">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0"><%= data.title || pageTitle %></h1>
        <small class="text-muted"><%= data.total || data.items?.length || 0 %> proizvoda</small>
      </div>
      
      <% if (data.items && data.items.length > 0) { %>
        <div class="row g-3">
          <% data.items.forEach(function(item) { %>
            <div class="col-6 col-md-4">
              <%- include("../includes/components/card-item", { item: item }) %>
            </div>
          <% }) %>
        </div>
        <!-- Paginacija sa marginom odozgo -->
        <div class="mt-4">
          <%- include("../includes/pagination", { pagination: data.pagination }) %>
        </div>
      <% } else { %>
        <div class="text-center py-5 text-muted">
          <i class="bi bi-inbox fs-1 d-block mb-2"></i>
          <p>Nema proizvoda za prikaz</p>
        </div>
      <% } %>
    </div>
    
    <!-- Sidebar - Kategorije i Tagovi (DESNO) -->
    <div class="col-lg-3">
      <% if (data.categories && data.categories.length > 0) { %>
        <div class="card mb-4">
          <div class="card-header">
            <h2 class="h6 card-title mb-0">Kategorije</h2>
          </div>
          <div class="list-group list-group-flush">
            <a href="/prodavnica" class="list-group-item list-group-item-action">Sve kategorije</a>
            <% data.categories.forEach(function(cat) { %>
              <a href="/prodavnica/kategorija/<%= cat.slug %>" class="list-group-item list-group-item-action<%= data.category && data.category.slug === cat.slug ? ' active' : '' %>">
                <%= cat.naziv %>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>
      
      <% if (data.tags && Object.keys(data.tags).length > 0) { %>
        <div class="card mb-4">
          <div class="card-header">
            <h2 class="h6 card-title mb-0">Filteri</h2>
          </div>
          <div class="card-body">
            <% Object.entries(data.tags).forEach(function(entry) { %>
              <% if (entry[1] && entry[1].length > 0) { %>
                <div class="mb-3">
                  <p class="small fw-semibold text-muted mb-2"><%= entry[0] %></p>
                  <div class="d-flex flex-wrap gap-1">
                    <% entry[1].forEach(function(tag) { %>
                      <a href="/prodavnica/tag/<%= tag.slug %>/<%= tag.tip || tag.type %>" 
                         class="badge bg-light text-dark text-decoration-none"><%= tag.naziv %></a>
                    <% }) %>
                  </div>
                </div>
              <% } %>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include("../includes/footer") %>