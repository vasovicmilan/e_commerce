<article class="card h-100 border-0 shadow-sm product-card" data-product-id="<%= item.id %>">
  <figure class="card-img-top position-relative mb-0 overflow-hidden">
    <a href="/prodavnica/artikal/<%= item.slug %>" class="d-block" aria-label="<%= item.naziv %>">
      <% if (item.slika) { %>
        <!-- 🔥 IZMENA: direktno koristi item.slika (string) umesto item.slika.url -->
        <img src="<%= item.slika %>" alt="<%= item.naziv %>" 
             class="w-100 product-card-img" loading="lazy" width="300" height="300">
      <% } else { %>
        <div class="bg-light d-flex align-items-center justify-content-center product-card-placeholder" 
             role="img" aria-label="Nema slike">
          <i class="bi bi-image text-muted fs-1"></i>
        </div>
      <% } %>
    </a>
    <% if (item.naAkciji) { %>
      <span class="badge bg-danger position-absolute top-0 end-0 m-2">Akcija</span>
    <% } %>
  </figure>
  
  <div class="card-body d-flex flex-column">
    <% if (item.kategorije && item.kategorije.length > 0) { %>
      <p class="small text-muted mb-1">
        <% item.kategorije.slice(0, 2).forEach(function(cat, i) { %>
          <a href="/prodavnica/kategorija/<%= cat.slug %>" class="text-muted text-decoration-none"><%= cat.naziv %></a><%= i < Math.min(item.kategorije.length, 2) - 1 ? ', ' : '' %>
        <% }) %>
      </p>
    <% } %>
    
    <h3 class="h6 card-title">
      <a href="/prodavnica/artikal/<%= item.slug %>" class="text-decoration-none text-dark stretched-link">
        <%= item.naziv %>
      </a>
    </h3>
    
    <% if (item.prosecnaOcena > 0) { %>
      <div class="mb-2" aria-label="Ocena: <%= item.prosecnaOcena %> od 5">
        <% for (let i = 1; i <= 5; i++) { %>
          <i class="bi bi-star<%= i <= Math.round(item.prosecnaOcena) ? '-fill' : '' %> small <%= i <= Math.round(item.prosecnaOcena) ? 'text-warning' : 'text-muted' %>"></i>
        <% } %>
        <small class="text-muted ms-1">(<%= item.brojOcena %>)</small>
      </div>
    <% } %>
    
    <div class="mt-auto">
      <div class="d-flex align-items-center gap-2">
        <% if (item.naAkciji && item.originalnaCena) { %>
          <span class="fw-bold text-danger"><%= item.cena %> RSD</span>
          <span class="text-muted text-decoration-line-through small"><%= item.originalnaCena %> RSD</span>
        <% } else { %>
          <span class="fw-bold"><%= item.cena %> RSD</span>
        <% } %>
      </div>
      
      <button type="button" class="btn btn-primary btn-sm w-100 mt-2" 
              data-add-to-cart 
              data-item-id="<%= item.id %>" 
              data-item-slug="<%= item.slug %>"
              aria-label="Dodaj <%= item.naziv %> u korpu">
        <i class="bi bi-cart-plus"></i> Dodaj u korpu
      </button>
    </div>
  </div>
</article>