<article class="card h-100 border-0 shadow-sm">
  <figure class="card-img-top mb-0 overflow-hidden">
    <a href="/blog/<%= post.slug %>" class="d-block" aria-label="<%= post.naziv %>">
      <% if (post.slika && post.slika.url) { %>
        <img src="/images/posts/<%= post.slika.url %>" alt="<%= post.slika.opis || post.naziv %>" 
             class="w-100 blog-card-img" loading="lazy" width="400" height="225">
      <% } else { %>
        <div class="bg-light d-flex align-items-center justify-content-center blog-card-placeholder" 
             role="img" aria-label="Nema slike">
          <i class="bi bi-image text-muted fs-1"></i>
        </div>
      <% } %>
    </a>
  </figure>
  
  <div class="card-body d-flex flex-column">
    <% if (post.kategorije && post.kategorije.length > 0) { %>
      <p class="small text-muted mb-1">
        <% post.kategorije.slice(0, 2).forEach(function(cat, i) { %>
          <a href="/blog/kategorija/<%= cat.slug %>" class="text-muted text-decoration-none"><%= cat.naziv %></a><%= i < Math.min(post.kategorije.length, 2) - 1 ? ', ' : '' %>
        <% }) %>
      </p>
    <% } %>
    
    <h3 class="h6 card-title">
      <a href="/blog/<%= post.slug %>" class="text-decoration-none text-dark stretched-link">
        <%= post.naziv %>
      </a>
    </h3>
    
    <p class="card-text small text-muted"><%= post.kratakOpis %></p>
    
    <div class="mt-auto d-flex justify-content-between align-items-center">
      <small class="text-muted">
        <time datetime="<%= post.datum %>"><%= post.datum %></time>
      </small>
      <% if (post.vremeCitanja) { %>
        <small class="text-muted">
          <i class="bi bi-clock"></i> <%= post.vremeCitanja %> min
        </small>
      <% } %>
    </div>
  </div>
</article>