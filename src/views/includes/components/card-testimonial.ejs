<blockquote class="card h-100 border-0 shadow-sm">
  <div class="card-body">
    <div class="mb-3" aria-label="Ocena: <%= testimonial.ocena %> od 5">
      <% for (let i = 1; i <= 5; i++) { %>
        <i class="bi bi-star<%= i <= testimonial.ocena ? '-fill' : '' %> <%= i <= testimonial.ocena ? 'text-warning' : 'text-muted' %>"></i>
      <% } %>
    </div>
    
    <p class="card-text fst-italic">"<%= testimonial.komentar %>"</p>
    
    <footer class="d-flex align-items-center gap-2 mt-auto">
      <% if (testimonial.avatar) { %>
        <img src="/images/<%= testimonial.avatar %>" alt="<%= testimonial.ime %>" 
             class="rounded-circle" width="40" height="40" loading="lazy">
      <% } else { %>
        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold"
             style="width: 40px; height: 40px;" aria-hidden="true">
          <%= (testimonial.ime || 'A').charAt(0).toUpperCase() %>
        </div>
      <% } %>
      <div>
        <cite class="fw-semibold not-italic"><%= testimonial.ime %></cite>
        <% if (testimonial.proizvod) { %>
          <p class="small text-muted mb-0">
            <a href="/prodavnica/artikal/<%= testimonial.proizvodSlug %>" class="text-muted text-decoration-none">
              <%= testimonial.proizvod %>
            </a>
          </p>
        <% } %>
        <p class="small text-muted mb-0">
          <time datetime="<%= testimonial.datum %>"><%= testimonial.datum %></time>
        </p>
      </div>
    </footer>
  </div>
</blockquote>