<!DOCTYPE html>
<html lang="sr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO -->
  <title><%= typeof seo !== 'undefined' ? seo.pageTitle || pageTitle : pageTitle %></title>
  <meta name="description" content="<%= typeof seo !== 'undefined' ? seo.pageDescription || pageDescription : pageDescription %>">
  <% if (typeof seo !== 'undefined' && seo.pageRobots) { %>
  <meta name="robots" content="<%= seo.pageRobots %>">
  <% } else { %>
  <meta name="robots" content="index, follow">
  <% } %>
  <link rel="canonical" href="<%= typeof seo !== 'undefined' ? seo.pageCanonical || '' : '' %>">
  
  <!-- Open Graph -->
  <meta property="og:title" content="<%= typeof seo !== 'undefined' ? seo.pageTitle || pageTitle : pageTitle %>">
  <meta property="og:description" content="<%= typeof seo !== 'undefined' ? seo.pageDescription || pageDescription : pageDescription %>">
  <meta property="og:type" content="website">
  <% if (typeof seo !== 'undefined' && seo.pageOgImage) { %>
  <meta property="og:image" content="<%= seo.pageOgImage %>">
  <% } %>
  
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/images/site/favicon.ico">
  <link rel="apple-touch-icon" href="/images/site/apple-touch-icon.png">
  
  <!-- Bootstrap CSS -->
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Custom CSS (samo varijable) -->
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>