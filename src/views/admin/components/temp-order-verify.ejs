<form method="POST" action="/admin/privremene-porudzbine/<%= data.orderId %>/potvrdi" data-form>
  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
  
  <button type="submit" class="btn btn-sm btn-success w-100" data-submit-btn>
    <i class="bi bi-check-lg"></i> <span data-submit-label>Potvrdi porudžbinu</span>
    <span class="spinner-border spinner-border-sm d-none" role="status" data-submit-spinner></span>
  </button>
  
  <small class="text-muted d-block mt-1">
    <i class="bi bi-info-circle"></i> Token ističe: <strong><%= data.tokenExpiration %></strong>
    <br><span class="text-warning">Napomena: Admin može potvrditi čak i ako je token istekao.</span>
  </small>
</form>