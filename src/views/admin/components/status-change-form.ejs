<form method="POST" action="<%= data.basePath ? data.basePath + '/' + data.entityId + '/status' : (typeof data.itemId !== 'undefined' ? '/admin/artikli/' + data.itemId + '/status' : '/admin/porudzbine/' + data.orderId + '/status') %>" data-form>
  <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
  <input type="hidden" name="_method" value="PUT">
  
  <div class="mb-2">
    <label for="statusSelect_<%= data.entityId || data.itemId || data.orderId || data.postId %>" class="form-label small text-muted">Novi status</label>
    <select id="statusSelect_<%= data.entityId || data.itemId || data.orderId || data.postId %>" name="status" class="form-select form-select-sm" data-auto-submit>
      <option value="">Izaberite status</option>
      <% if (typeof data.statuses !== 'undefined') { %>
        <% data.statuses.forEach(function(status) { %>
          <option value="<%= status %>" <%= data.currentStatus === status ? 'selected' : '' %>>
            <%= typeof data.statusMap !== 'undefined' && data.statusMap[status] ? data.statusMap[status] : status %>
          </option>
        <% }) %>
      <% } %>
      <% if (typeof data.allowedStatuses !== 'undefined') { %>
        <% data.allowedStatuses.forEach(function(status) { %>
          <option value="<%= status %>" <%= data.currentStatus === status ? 'selected' : '' %>>
            <%= typeof data.statusMap !== 'undefined' && data.statusMap[status] ? data.statusMap[status] : status %>
          </option>
        <% }) %>
      <% } %>
    </select>
  </div>
  
  <button type="submit" class="btn btn-sm btn-primary w-100" data-submit-btn>
    <i class="bi bi-arrow-repeat"></i> <span data-submit-label>Promeni status</span>
    <span class="spinner-border spinner-border-sm d-none" role="status" data-submit-spinner></span>
  </button>
</form>