<div class="d-grid gap-2">
  <!-- Promena statusa -->
  <form method="POST" action="/admin/korisnici/<%= data.userId %>/status" data-form>
    <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
    <input type="hidden" name="_method" value="PUT">
    <select name="status" class="form-select form-select-sm mb-2" data-auto-submit>
      <option value="">Promeni status</option>
      <option value="active" <%= data.currentStatus === 'active' ? 'selected' : '' %>>Aktivan</option>
      <option value="inactive" <%= data.currentStatus === 'inactive' ? 'selected' : '' %>>Neaktivan</option>
      <option value="suspended" <%= data.currentStatus === 'suspended' ? 'selected' : '' %>>Suspendovan</option>
    </select>
  </form>

  <!-- Verifikacija (samo ako nije verifikovan) -->
  <% if (!data.isConfirmed) { %>
    <form method="POST" action="/admin/korisnici/<%= data.userId %>/verifikuj" data-form>
      <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
      <input type="hidden" name="_method" value="PUT">
      <button type="submit" class="btn btn-sm btn-success w-100" data-submit-btn>
        <i class="bi bi-check-lg"></i> <span data-submit-label>Verifikuj nalog</span>
        <span class="spinner-border spinner-border-sm d-none" role="status" data-submit-spinner></span>
      </button>
    </form>
  <% } %>

  <!-- Promena role -->
  <% if (data.roleOptions && data.roleOptions.length > 0) { %>
    <form method="POST" action="/admin/korisnici/<%= data.userId %>/rola" data-form>
      <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
      <input type="hidden" name="_method" value="PUT">
      <div class="mb-2">
        <label for="roleSelect_<%= data.userId %>" class="form-label small text-muted">Dodeljena rola</label>
        <select id="roleSelect_<%= data.userId %>" name="role" class="form-select form-select-sm" data-auto-submit>
          <!-- Prikaz trenutne role kao prve opcije (disabled) -->
          <option value="" disabled <%= !data.currentRoleId ? 'selected' : '' %>>
            Trenutna rola: <%= data.currentRoleName || 'Nije dodeljena' %>
          </option>
          <% data.roleOptions.forEach(function(role) { %>
            <option value="<%= role.value %>" <%= data.currentRoleId === role.value ? 'selected' : '' %>>
              <%= role.label %>
            </option>
          <% }) %>
        </select>
      </div>
    </form>
  <% } %>

  <form method="POST" action="/admin/korisnici/<%= data.userId %>/partner" data-form>
    <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
    <input type="hidden" name="_method" value="PUT">
    <input type="hidden" name="isPartner" value="<%= data.isPartner ? 'false' : 'true' %>">
    
    <button type="submit" class="btn btn-sm <%= data.isPartner ? 'btn-outline-danger' : 'btn-outline-success' %> w-100" data-submit-btn>
      <i class="bi bi-<%= data.isPartner ? 'person-x' : 'person-plus' %>"></i>
      <span data-submit-label><%= data.isPartner ? 'Deaktiviraj partnerstvo' : 'Aktiviraj partnerstvo' %></span>
      <span class="spinner-border spinner-border-sm d-none" role="status" data-submit-spinner></span>
    </button>
  </form>

    <!-- Ako je korisnik partner, prikazujemo dugme za uređivanje -->
  <% if (data.isPartner) { %>
    <a href="/admin/korisnici/<%= data.userId %>/partner/edit" class="btn btn-sm btn-outline-primary w-100">
      <i class="bi bi-gear"></i> Uredi partnerstvo
    </a>
  <% } %>
</div>