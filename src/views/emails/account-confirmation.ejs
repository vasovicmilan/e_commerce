<%
const subject = `Dobrodošli u ${SITE_NAME} - Potvrdite vaš nalog`;
const body = `
  <p>Zdravo ${firstName},</p>
  <p>Hvala vam što ste kreirali nalog na ${SITE_NAME}. Da biste ga aktivirali, kliknite na dugme ispod:</p>
  <p style="text-align: center; margin: 25px 0;">
    <a href="${confirmationUrl}" style="display: inline-block; background-color: #e91e63; color: #ffffff; padding: 12px 30px; text-decoration: none; border-radius: 4px; font-weight: bold;">Potvrdi nalog</a>
  </p>
  <p>Ili kopirajte ovaj link u vaš pretraživač:</p>
  <p style="word-break: break-all; color: #666; font-size: 14px;">${confirmationUrl}</p>
  <p style="margin-top: 25px; color: #999; font-size: 14px;">Link je validan 24 sata. Ako niste vi kreirali ovaj nalog, ignorišite ovaj email.</p>
`;
%>
<%- include("_layout", { subject, body }) %>