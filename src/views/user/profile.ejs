<%- include("../includes/head") %>
<%- include("../includes/navigation") %>

<main class="container-fluid py-4">
  <%- include("../includes/breadcrumbs") %>
  <%- include("../includes/flash-messages") %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><%= pageTitle %></h1>
  </div>

  <div class="row g-4">
    <!-- Sidebar -->
    <div class="col-lg-3">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center">
          <div class="mb-3">
            <img
              src="<%= data.user?.avatar || data.user?.osnovno?.avatar || '/images/default-avatar.png' %>"
              alt="Avatar"
              class="rounded-circle img-fluid avatar-profile"
            />
          </div>
          <h5 class="mb-0"><%= data.user?.fullName || (data.user?.osnovno?.ime || '') + ' ' + (data.user?.osnovno?.prezime || '') || 'Korisnik' %></h5>
          <small class="text-muted"><%= data.user?.email || data.user?.osnovno?.email || '' %></small>
          <hr>
          <div class="list-group list-group-flush text-start">
            <a href="/profil/moj-profil?tab=profile" class="list-group-item list-group-item-action <%= data.activeTab === 'profile' ? 'active' : '' %>">
              <i class="bi bi-person"></i> Moj profil
            </a>
            <a href="/profil/porudzbine?tab=orders" class="list-group-item list-group-item-action <%= data.activeTab === 'orders' ? 'active' : '' %>">
              <i class="bi bi-box"></i> Moje porudžbine
            </a>
            <a href="/profil/zelje?tab=wishlist" class="list-group-item list-group-item-action <%= data.activeTab === 'wishlist' ? 'active' : '' %>">
              <i class="bi bi-heart"></i> Lista želja
            </a>
            <% if (data.partner) { %>
            <a href="/profil/moja-prodavnica?tab=shop" class="list-group-item list-group-item-action <%= data.activeTab === 'shop' ? 'active' : '' %>">
              <i class="bi bi-shop"></i> Moja prodavnica
            </a>
            <% } %>
            <a href="/profil/podesavanja?tab=settings" class="list-group-item list-group-item-action <%= data.activeTab === 'settings' ? 'active' : '' %>">
              <i class="bi bi-gear"></i> Podešavanja
            </a>
          </div>
        </div>
      </div>

      <!-- Partner info if exists (samo na profile tab-u) -->
      <% if (data.partner && data.activeTab === 'profile') { %>
      <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
          <h6 class="mb-2"><i class="bi bi-star text-warning"></i> Partner status</h6>
          <p class="mb-0 small">
            <span class="badge bg-<%= data.partner.shopStatus ? 'success' : 'secondary' %>">
              <%= data.partner.shopStatus ? 'Aktivna' : 'Neaktivna' %>
            </span>
            <% if (data.partner.novčanik > 0) { %>
            <br><strong>Novčanik:</strong> <%= data.partner.novčanik %> RSD
            <% } %>
          </p>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Main content -->
    <div class="col-lg-9">
      <!-- Uključi odgovarajući tab na osnovu activeTab -->
      <% if (data.activeTab === 'profile') { %>
        <%- include("_profile-tab") %>
      <% } else if (data.activeTab === 'orders') { %>
        <%- include("_orders-tab") %>
      <% } else if (data.activeTab === 'wishlist') { %>
        <%- include("_wishlist-tab") %>
      <% } else if (data.activeTab === 'shop') { %>
        <%- include("_shop-tab") %>
      <% } else if (data.activeTab === 'settings') { %>
        <%- include("_settings-tab") %>
      <% } %>
    </div>
  </div>
</main>

<!-- Delete confirmation modal (za telefone/adrese) -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title">Potvrda brisanja</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Da li ste sigurni da želite da obrišete ovaj unos?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Otkaži</button>
        <form id="deleteForm" method="POST">
          <input type="hidden" name="_method" value="DELETE">
          <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-danger">Obriši</button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Deactivate confirmation modal (za deaktivaciju naloga) -->
<div class="modal fade" id="deactivateModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title text-danger">Potvrda deaktivacije</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">
          Da li ste sigurni da želite da <strong>deaktivirate</strong> svoj nalog?<br>
          Ova radnja je <strong>trajna</strong> i ne može se poništiti.
        </p>
        <p class="text-muted small mt-2">
          Morate uneti lozinku za potvrdu.
        </p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Otkaži</button>
        <form id="deactivateForm" action="/profil/podesavanja/deaktiviraj" method="POST">
          <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
          <div class="mb-2">
            <input
              type="password"
              class="form-control form-control-sm"
              id="modalPassword"
              name="password"
              placeholder="Unesite lozinku"
              required
            />
          </div>
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-exclamation-triangle"></i> Deaktiviraj
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="/js/profile.js"></script>
<script src="/js/details.js"></script>
<script src="/js/settings.js"></script>
<%- include("../includes/footer") %>